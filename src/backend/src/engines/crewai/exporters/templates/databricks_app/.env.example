# Make a copy of this to set environment variables for local development
# cp .env.example .env

# TODO: Fill in auth related env vars
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://<your-workspace-here>.databricks.com
# DATABRICKS_TOKEN=dapi....

# TODO: Update with the MLflow experiment you want to log traces and models to
MLFLOW_EXPERIMENT_ID=

CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"

# Local-only alternative (no Databricks): run a local MLflow server and watch
# chat turns + sessions in its Traces UI. Replace the two MLFLOW_* lines above with:
#   MLFLOW_TRACKING_URI=http://127.0.0.1:5555
#   MLFLOW_EXPERIMENT_NAME=kasal-local-dev
# then start the server (separate terminal):
#   mlflow server --backend-store-uri sqlite:///$HOME/.mlflow-kasal/mlflow.db \
#     --default-artifact-root file:$HOME/.mlflow-kasal/artifacts --host 127.0.0.1 --port 5555
# Each conversation groups under one session (metadata mlflow.trace.session); filter
# in the UI with:  metadata.`mlflow.trace.session` = '<conversation-id>'

# A2UI generative UI (compose answers into renderable surfaces). "false" disables.
A2UI_ENABLED=true
# Source citations: agents cite tool-sourced claims with inline [n](url) markdown
# links + a "## Sources" list; the UI renders [n] as a clickable reference. 0=off.
CITATIONS=true
# Runaway/hang guards (the Stop button cancels on demand; these auto-cap spend):
#   LLM_REQUEST_TIMEOUT     per LLM HTTP call in seconds (a hung call fails fast)
#   CREW_TIMEOUT_SECONDS    whole-turn wall clock; on expiry the crew is cancelled (0=off)
#   AGENT_MAX_EXECUTION_TIME optional native per-agent cap in seconds (0=off)
LLM_REQUEST_TIMEOUT=300
CREW_TIMEOUT_SECONDS=600
# AGENT_MAX_EXECUTION_TIME=0
# Drop specific MCP tools by name (comma-separated), ALWAYS off in every mode:
# MCP_DISABLED_TOOLS=
# Answer modes (the UI picks per request: chat | research | deep):
#   chat     = one fast agent, no crew      research = full crew, fast tools
#   deep     = full crew, deep tools + reasoning
# CREW_MODE                 default mode when the client sends none (default: research)
# FAST_MAX_ITER             per-agent tool-loop cap in research mode (default: 5)
# CHAT_MAX_ITER             tool-loop cap for the chat agent (default: 6)
# FAST_MODE_DISABLED_TOOLS  tools dropped in chat/research but kept in deep — point
#                           the deep (slow) MCP tools here so deep mode can use them:
# CREW_MODE=research
# FAST_MODE_DISABLED_TOOLS=perplexity_research,perplexity_reason
# Optional: route every model (crew + A2UI composer) to a local OpenAI-compatible
# endpoint (e.g. a vLLM server) instead of Databricks — no Databricks auth needed.
# LOCAL_LLM_BASE_URL=http://localhost:8000/v1
# LOCAL_LLM_API_KEY=dummy
# The crew's configured model names (e.g. databricks-gpt-5-3-codex) won't exist on
# a local server — set LOCAL_LLM_MODEL to a model it actually serves so every call
# uses it (otherwise the server returns 404 "model does not exist").
# LOCAL_LLM_MODEL=Qwen3-Coder-30B-A3B-Instruct
# Optional: force a fixed temperature for the local endpoint. Some hosted models
# reject the app's defaults — e.g. Kimi/Moonshot K2 only allows temperature=1.
# LOCAL_LLM_TEMPERATURE=1

# Optional: override the LLM model for every agent (otherwise each agent's own
# llm from config/agents.yaml is used). Edit MODEL_OVERRIDE in agent_server/agent.py.
# CrewAI tool API keys (only the ones your crew uses):
{{ENV_TOOL_KEYS}}
