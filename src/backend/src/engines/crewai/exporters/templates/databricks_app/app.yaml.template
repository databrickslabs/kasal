command: ["uv", "run", "start-app"]
# databricks apps listen by default on port 8000

env:
  - name: MLFLOW_TRACKING_URI
    value: "databricks"
  - name: MLFLOW_REGISTRY_URI
    value: "databricks-uc"
  - name: API_PROXY
    value: "http://localhost:8000/invocations"
  - name: CHAT_APP_PORT
    value: "3000"
  - name: CHAT_PROXY_TIMEOUT_SECONDS
    value: "300"
  # A2UI generative UI: compose the agent's answer into a declarative surface the
  # frontend renders (presentation/dashboard/mindmap/...). Set "false" to disable.
  - name: A2UI_ENABLED
    value: "true"
  # Source citations: agents cite tool-sourced claims with inline [n](url) links +
  # a "## Sources" list; the UI renders [n] as a clickable reference. "false"=off.
  - name: CITATIONS
    value: "true"
  # Runaway/hang guards so a stuck turn can't burn tokens forever. The Stop button
  # cancels a turn on demand; these are the automatic safety nets.
  #   LLM_REQUEST_TIMEOUT  — per LLM call (s); a hung call fails instead of hanging.
  #   CREW_TIMEOUT_SECONDS — whole turn (s); on expiry the crew is cancelled. 0=off.
  - name: LLM_REQUEST_TIMEOUT
    value: "300"
  - name: CREW_TIMEOUT_SECONDS
    value: "600"
  - name: MLFLOW_EXPERIMENT_ID
    value: "{{EXPERIMENT_ID}}"
  # The app creates this MLflow experiment, bound to Unity Catalog at creation.
  - name: MLFLOW_EXPERIMENT_NAME
    value: "{{MLFLOW_EXPERIMENT_NAME}}"
  - name: DATABRICKS_CATALOG
    value: "{{DATABRICKS_CATALOG}}"
  - name: DATABRICKS_SCHEMA
    value: "{{DATABRICKS_SCHEMA}}"
  # SQL warehouse used to provision the experiment's Unity Catalog trace tables.
  - name: DATABRICKS_WAREHOUSE_ID
    value: "{{DATABRICKS_WAREHOUSE_ID}}"
  # Lakebase instance attached to this app (empty if none). The instance is
  # bound as an app `database` resource so the app SP can connect to it.
  - name: LAKEBASE_INSTANCE_NAME
    value: "{{LAKEBASE_INSTANCE}}"
  - name: LAKEBASE_DATABASE_NAME
    value: "{{LAKEBASE_DATABASE}}"
