[project]
name = "{{BUNDLE_NAME}}"
version = "0.1.0"
description = "{{DESCRIPTION}}"
readme = "README.md"
authors = [
    { name = "Agent Developer", email = "developer@example.com" }
]
requires-python = ">=3.11"
dependencies = [
    "fastapi>=0.129.0",
    "uvicorn>=0.41.0",
    # Pin crewai + litellm to the exact pair Kasal tests against. CrewAI routes
    # Databricks models (databricks/<endpoint>) through its LiteLLM fallback, but
    # crewai 1.14.5 only enables that fallback when an EXACTLY compatible litellm
    # is importable (it imports version-sensitive litellm submodules at startup).
    # This app ships no uv.lock, so loose floors let `uv sync` resolve a
    # mismatched crewai+litellm pair and fail at runtime with
    # "the LiteLLM fallback package is not installed". These pins avoid that.
    "crewai[tools]==1.14.5",
    "litellm==1.74.9",
    "databricks-agents>=1.4.0",
    "databricks-sdk>=0.102.0",
    "mlflow>=3.11,<4",
    "pyyaml>=6.0",
    "python-dotenv>=1.2.1",
    "opentelemetry-exporter-otlp-proto-grpc>=1.25.0",
    # Durable conversation state (agent_server/state_store.py) on the attached
    # Lakebase instance; without Lakebase the store falls back to SQLite (stdlib).
    # pg8000 is pure Python and BSD-licensed (psycopg is LGPL — avoid).
    "pg8000>=1.31",
{{EXTRA_DEPENDENCIES}}]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
# Run from source via PYTHONPATH on Databricks Apps; never build a wheel.
packages = ["agent_server", "scripts"]

[dependency-groups]
dev = [
    "hatchling>=1.28.0",
    "pytest>=9.0.2",
]

setup = [
    "ruamel.yaml>=0.18.0",
]

[tool.uv]
default-groups = ["dev", "setup"]


[project.scripts]
quickstart = "scripts.quickstart:main"
start-app = "scripts.start_app:main"
start-server = "agent_server.start_server:main"
agent-evaluate = "agent_server.evaluate_agent:evaluate"
discover-tools = "scripts.discover_tools:main"
preflight = "scripts.preflight:main"
